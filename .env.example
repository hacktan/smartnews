# DuckDB database path (relative to project root or absolute)
DB_PATH=smartnews.duckdb

# OpenAI API
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pipeline tuning (optional — defaults shown)
ENRICHMENT_BATCH_LIMIT=50
SCRAPE_BATCH_LIMIT=100

# API settings (optional — defaults shown)
CORS_ORIGINS=*
CACHE_TTL_SECONDS=180
HOME_TOP_STORIES_LIMIT=10
CATEGORY_PAGE_SIZE=20
SEARCH_MAX_RESULTS=30

# API startup download (required in Render if DB is not baked into image)
# Optional (recommended for private repos/rate limits)
GITHUB_TOKEN=ghp_xxx
# Optional override for repository slug used by startup downloader
GITHUB_REPOSITORY=hacktan/smartnews
GITHUB_RELEASE_TAG=db-latest
GITHUB_DB_ASSET_NAME=smartnews.duckdb
